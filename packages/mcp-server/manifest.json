{
  "dxt_version": "0.2",
  "name": "influship-api-mcp",
  "version": "0.1.0",
  "description": "The official MCP Server for the Influship API API",
  "author": {
    "name": "Influship API",
    "email": "support@influship.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Influship/influship-sdk-typescript.git"
  },
  "homepage": "https://github.com/Influship/influship-sdk-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.influship.com",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "INFLUSHIP_API_KEY": "${user_config.INFLUSHIP_API_KEY}"
      }
    }
  },
  "user_config": {
    "INFLUSHIP_API_KEY": {
      "title": "api_key",
      "description": "API key for authentication",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
